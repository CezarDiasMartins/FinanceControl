@model FinanceControl.Core.ViewModels.LoginViewModel
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-box">
    <h1 class="h3 mb-3">Entrar</h1>
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="mb-3">
            @Html.LabelFor(x => x.Email, new { @class = "form-label" })
            @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", autocomplete = "email" })
            @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger" })
        </div>
        <div class="mb-3">
            @Html.LabelFor(x => x.Senha, new { @class = "form-label" })
            @Html.PasswordFor(x => x.Senha, new { @class = "form-control", autocomplete = "current-password" })
            @Html.ValidationMessageFor(x => x.Senha, "", new { @class = "text-danger" })
        </div>
        <button class="btn btn-primary w-100" type="submit">
            <i class="fa-solid fa-right-to-bracket me-1"></i>Entrar
        </button>
    }
    <a class="btn btn-outline-secondary w-100 mt-2" href="@Url.Action("Cadastro", "Auth")">
        <i class="fa-solid fa-user-plus me-1"></i>Criar conta
    </a>
    <div class="text-center mt-3 small">
        Esqueceu sua senha?
        <a class="link-primary text-decoration-underline" href="@Url.Action("RecuperarSenha", "Auth")">Clique aqui</a>
    </div>
</div>
