<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - FinanceControl</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            @Html.ActionLink("FinanceControl", "Index", "Home", new { area = "" }, new { @class = "navbar-brand fw-semibold" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                @if (Session["UsuarioId"] != null)
                {
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">@Html.ActionLink("Home", "Index", "Home", null, new { @class = "nav-link" })</li>
                        @if (ViewBag.UsuarioEhAdmin == true)
                        {
                            <li class="nav-item">@Html.ActionLink("Usuários", "Index", "User", null, new { @class = "nav-link" })</li>
                        }
                    </ul>
                    <div class="navbar-actions d-flex align-items-center gap-2 text-white ms-auto">
                        <a class="btn btn-sm btn-outline-light btn-icon" href="@Url.Action("Perfil", "User")" title="Perfil" aria-label="Perfil">
                            <i class="fa-solid fa-user"></i>
                        </a>
                        <a class="btn btn-sm btn-outline-light btn-icon" href="@Url.Action("Logout", "Auth")" title="Sair" aria-label="Sair">
                            <i class="fa-solid fa-right-from-bracket"></i>
                        </a>
                    </div>
                }
            </div>
        </div>
    </nav>
    <main class="container body-content py-4">
        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alert alert-success">@TempData["MensagemSucesso"]</div>
        }
        @if (TempData["MensagemErro"] != null)
        {
            <div class="alert alert-danger">@TempData["MensagemErro"]</div>
        }
        @if (TempData["LinkRecuperacaoSenha"] != null)
        {
            <div class="alert alert-info d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-2">
                <span>Modo demonstração: use o link gerado para redefinir a senha.</span>
                <a class="btn btn-sm btn-primary" href="@TempData["LinkRecuperacaoSenha"]">
                    <i class="fa-solid fa-key me-1"></i>Redefinir senha
                </a>
            </div>
        }
        @RenderBody()
    </main>
    <footer class="container pb-4 text-muted small">
        &copy; @DateTime.Now.Year - FinanceControl
    </footer>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script>
        $(function () {
            function aplicarMascaraCpf(valor) {
                var numeros = (valor || '').replace(/\D/g, '').substring(0, 11);
                if (numeros.length > 9) {
                    return numeros.replace(/(\d{3})(\d{3})(\d{3})(\d{0,2})/, '$1.$2.$3-$4');
                }
                if (numeros.length > 6) {
                    return numeros.replace(/(\d{3})(\d{3})(\d{0,3})/, '$1.$2.$3');
                }
                if (numeros.length > 3) {
                    return numeros.replace(/(\d{3})(\d{0,3})/, '$1.$2');
                }
                return numeros;
            }

            $('.cpf-mask').each(function () {
                $(this).val(aplicarMascaraCpf($(this).val()));
            });

            $(document).on('input', '.cpf-mask', function () {
                $(this).val(aplicarMascaraCpf($(this).val()));
            });
        });
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
