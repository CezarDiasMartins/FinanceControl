@model FinanceControl.Core.ViewModels.FinanceListagemViewModel
@{
    var totalPaginas = Model.TotalPaginas();
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <span class="text-muted small">@Model.TotalRegistros registro(s)</span>
    <nav aria-label="Paginacao">
        <ul class="pagination pagination-sm mb-0">
            @for (var pagina = 1; pagina <= totalPaginas; pagina++)
            {
                <li class="page-item @(pagina == Model.Pagina ? "active" : "")">
                    <button type="button" class="page-link pagina-link" data-pagina="@pagina">@pagina</button>
                </li>
            }
        </ul>
    </nav>
</div>
